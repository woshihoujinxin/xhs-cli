# xhs-cli landing — 部署配置模板
# 复制为 .env.deploy 并填写真实值，不要提交到 Git

# ─── Docker 镜像仓库 ───────────────────────────────────────────────────────────
# 阿里云示例：registry.cn-shanghai.aliyuncs.com/your-namespace
# Docker Hub 示例：docker.io/your-username
DOCKER_REGISTRY=registry.cn-shanghai.aliyuncs.com/your-namespace
DOCKER_USERNAME=your-registry-username
DOCKER_PASSWORD=your-registry-password

# ─── 目标服务器（SSH）─────────────────────────────────────────────────────────
SSH_HOST=your.server.ip
SSH_USERNAME=root
SSH_PASSWORD=your-ssh-password
# SSH_PORT=22

# ─── 可选部署参数 ──────────────────────────────────────────────────────────────
# 镜像 tag，留空则用 latest（CI 环境可用 GITHUB_SHA 自动取前 7 位）
# DEPLOY_TAG=latest

# 镜像名，默认取 package.json 的 name 字段
# DOCKER_IMAGE_NAME=xhs-cli-landing

# 服务器上的容器名
# DEPLOY_CONTAINER_NAME=xhs-cli-landing

# 宿主机端口 -> 容器内 3000
# DEPLOY_PUBLISH_PORT=38521

# 容器时区（影响日志时间）
# DEPLOY_CONTAINER_TZ=Asia/Shanghai
