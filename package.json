{
  "name": "@easyasstudio/xhs-cli",
  "version": "1.4.10",
  "description": "小红书创作者 CLI(fork: 配置目录统一到 ~/.config/xhs-cli,与 xianyu-auto skill 约定一致)",
  "type": "module",
  "main": "dist/cli/index.js",
  "types": "dist/cli/index.d.ts",
  "bin": {
    "xhs": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build && npm run build:test && find dist-test -name '*.test.js' -print0 | xargs -0 node --test",
    "postpublish": "git checkout README.md",
    "dev": "npm run build && node dist/cli/index.js help",
    "deploy": "node scripts/deploy.mjs"
  },
  "keywords": [
    "xiaohongshu",
    "xhs",
    "小红书",
    "content-creator",
    "social-media",
    "automation",
    "cli",
    "crawler",
    "cover-generation",
    "image-generation"
  ],
  "author": "Joo <1546635571@qq.com> (original); fork maintained by woshihoujinxin",
  "license": "GPL-3.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woshihoujinxin/xhs-cli.git"
  },
  "bugs": {
    "url": "https://github.com/woshihoujinxin/xhs-cli/issues"
  },
  "homepage": "https://github.com/woshihoujinxin/xhs-cli#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "puppeteer-core": "^24.29.1"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.10.0",
    "jsdom": "^26.1.0",
    "ssh2": "^1.17.0",
    "typescript": "^5.3.3"
  }
}
